<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".screens.MaagarDrills"
    android:background="@color/dgreen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etSearchName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/white"
                android:padding="10dp"
                android:hint="Search drill by name..."
                android:inputType="text" />

            <Button
                android:id="@+id/btnToggleFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/black"
                android:textColor="@color/white"
                android:text="Filters"
                android:drawableEnd="@android:drawable/ic_menu_sort_by_size"/>
        </LinearLayout>

        <ScrollView
            android:id="@+id/filterLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:weightSum="3">

                    <Spinner
                        android:id="@+id/spinnerLevel"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp" />

                    <Spinner
                        android:id="@+id/spinnerBallColor"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp" />

                    <Spinner
                        android:id="@+id/spinnerCourtSize"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <EditText
                        android:id="@+id/etMinPlayers"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Min Players"
                        android:inputType="number" />

                    <EditText
                        android:id="@+id/etMaxPlayers"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Max Players"
                        android:inputType="number" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <EditText
                        android:id="@+id/etMinAge"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Min Age"
                        android:inputType="number" />

                    <EditText
                        android:id="@+id/etMaxAge"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Max Age"
                        android:inputType="number" />

                    <EditText
                        android:id="@+id/etMaxTime"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Max Time (m)"
                        android:inputType="number" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Required Shot Types:"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:rowCount="4">

                    <CheckBox android:id="@+id/cbForehand" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Forehand" />
                    <CheckBox android:id="@+id/cbBackhand" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Backhand" />
                    <CheckBox android:id="@+id/cbServe" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Serve" />

                    <CheckBox android:id="@+id/cbVolleyFh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Volley FH" />
                    <CheckBox android:id="@+id/cbVolleyBh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Volley BH" />
                    <CheckBox android:id="@+id/cbSmash" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Smash" />

                    <CheckBox android:id="@+id/cbDriveFh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Drive FH" />
                    <CheckBox android:id="@+id/cbDriveBh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Drive BH" />
                    <CheckBox android:id="@+id/cbForwardFh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fwd FH" />

                    <CheckBox android:id="@+id/cbForwardBh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fwd BH" />
                    <CheckBox android:id="@+id/cbSliceFh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Slice FH" />
                    <CheckBox android:id="@+id/cbSliceBh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Slice BH" />
                </GridLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:weightSum="3">

                    <Button
                        android:id="@+id/btnClearFilters"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        android:backgroundTint="#8B8B8B"
                        android:textColor="@color/white"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnApplyFilters"
                        android:layout_width="0dp"
                        android:layout_weight="2"
                        android:layout_height="wrap_content"
                        android:text="Apply Filters &amp; Close"
                        android:backgroundTint="#4CAF50"
                        android:textColor="@color/white"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerDrills"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>